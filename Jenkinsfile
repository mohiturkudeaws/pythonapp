pipeline{
    agent any
    stages{
        stage('clone code'){
            steps{
                echo 'Hello dosto'
            }
        }
        stage('build'){
            steps{
                echo 'Build code'
            }
        }
        stage('test'){
            steps{
                    echo 'Test code1'
                }
           
        }
        stage('deploy'){
            steps{
                echo 'Deploy code'
            }
        }
        stage('Smoke test'){
            steps{
                echo 'smoke test'
            }
        }
    }
}
